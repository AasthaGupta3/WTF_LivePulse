# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=wtf_livepulse
POSTGRES_USER=wtf
POSTGRES_PASSWORD=wtf_secret
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgres://wtf:wtf_secret@db:5432/wtf_livepulse

# ── CORS / Frontend ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── WebSocket ─────────────────────────────────────────────────────────────────
WS_HEARTBEAT_INTERVAL_MS=30000

# ── Cron / Anomaly Detection ──────────────────────────────────────────────────
ANOMALY_CRON_SCHEDULE=*/5 * * * *
ZERO_CHECKINS_THRESHOLD_MIN=60
CAPACITY_BREACH_THRESHOLD_PCT=90
REVENUE_DROP_THRESHOLD_PCT=30

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
